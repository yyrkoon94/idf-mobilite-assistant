import voluptuous as vol
import uuid
import aiohttp
from homeassistant import config_entries

from .const import (
    DOMAIN,
    CONF_API_KEY,
    CONF_NAME,
    CONF_MONITORING_REF,
    CONF_STOP_ID,
)

MENU_ADD_LIGNE = "add_ligne"
MENU_ADD_MESSAGE = "add_message"
MENU_DELETE = "delete"
MENU_UPDATE_API = "update_api"
MENU_EXIT = "exit"


class ConfigFlow(config_entries.ConfigFlow, domain=DOMAIN):
    VERSION = 1

    def __init__(self):
        self.entry = None
        self.api_key = None
        self._search_results = {}
        self._selected_stop_area = None

    # ---------------------------------------------------------
    # 1) API KEY → Première ligne
    # ---------------------------------------------------------
    async def async_step_user(self, user_input=None):
        existing = self._async_current_entries()

        if existing:
            self.entry = existing[0]
            return await self.async_step_main_menu()

        if user_input is not None:
            self.api_key = user_input[CONF_API_KEY]
            return await self.async_step_add_first_ligne()

        schema = vol.Schema({vol.Required(CONF_API_KEY): str})
        return self.async_show_form(step_id="user", data_schema=schema)

    # ---------------------------------------------------------
    # 2) Première ligne → Recherche StopArea
    # ---------------------------------------------------------
    async def async_step_add_first_ligne(self, user_input=None):
        if user_input is not None:
            # On stocke le nom temporairement
            self._first_line_name = user_input[CONF_NAME]
            return await self.async_step_search_stop_area(first_line=True)

        schema = vol.Schema(
            {
                vol.Required(CONF_NAME): str,
            }
        )

        return self.async_show_form(
            step_id="add_first_ligne",
            data_schema=schema,
            description_placeholders={"help": "Ajoutez votre première ligne."},
        )

    # ---------------------------------------------------------
    # 3) Recherche StopArea (API IDFM)
    # ---------------------------------------------------------
    async def async_step_search_stop_area(self, user_input=None, first_line=False):
        """Recherche d'un arrêt via l'API IDFM."""
        self._first_line = first_line

        if user_input is not None:
            query = user_input["query"]

            session = aiohttp.ClientSession()
            url = "https://prim.iledefrance-mobilites.fr/marketplace/stop-areas"

            try:
                async with session.get(
                    url,
                    headers={
                        "apiKey": self.api_key
                        if first_line
                        else self.entry.data[CONF_API_KEY]
                    },
                    params={"q": query},
                ) as resp:
                    data = await resp.json()
            except Exception:
                return self.async_show_form(
                    step_id="search_stop_area",
                    data_schema=vol.Schema({vol.Required("query"): str}),
                    errors={"base": "api_error"},
                )

            results = data.get("stopAreas", [])

            if not results:
                return self.async_show_form(
                    step_id="search_stop_area",
                    data_schema=vol.Schema({vol.Required("query"): str}),
                    errors={"base": "no_results"},
                )

            # On stocke les résultats
            self._search_results = {
                r["id"]: f"{r['name']} ({r.get('city', '')})" for r in results
            }

            return await self.async_step_select_stop_area()

        schema = vol.Schema({vol.Required("query"): str})
        return self.async_show_form(
            step_id="search_stop_area",
            data_schema=schema,
            description_placeholders={
                "help": "Tapez un nom de station, une ville ou un arrêt."
            },
        )

    # ---------------------------------------------------------
    # 4) Sélection StopArea
    # ---------------------------------------------------------
    async def async_step_select_stop_area(self, user_input=None):
        if user_input is not None:
            self._selected_stop_area = user_input["stop_area"]

            if self._first_line:
                return await self.async_step_create_first_entry()
            else:
                return await self.async_step_add_ligne_details()

        schema = vol.Schema({vol.Required("stop_area"): vol.In(self._search_results)})

        return self.async_show_form(
            step_id="select_stop_area",
            data_schema=schema,
            description_placeholders={"help": "Sélectionnez l'arrêt correspondant."},
        )

    # ---------------------------------------------------------
    # 5) Création de la première config_entry
    # ---------------------------------------------------------
    async def async_step_create_first_entry(self, user_input=None):
        lignes = [
            {
                "uuid": str(uuid.uuid4()),
                "name": self._first_line_name,
                "monitoring_ref": self._selected_stop_area,
            }
        ]

        data = {
            CONF_API_KEY: self.api_key,
            "lignes": lignes,
            "messages": [],
        }

        return self.async_create_entry(
            title="IDF Mobilité Assistant v2",
            data=data,
        )

    # ---------------------------------------------------------
    # MENU PRINCIPAL
    # ---------------------------------------------------------
    async def async_step_main_menu(self, user_input=None):
        if user_input is not None:
            choice = user_input["menu"]

            if choice == MENU_ADD_LIGNE:
                return await self.async_step_search_stop_area()

            if choice == MENU_ADD_MESSAGE:
                return await self.async_step_add_message()

            if choice == MENU_DELETE:
                return await self.async_step_delete()

            if choice == MENU_UPDATE_API:
                return await self.async_step_update_api()

            if choice == MENU_EXIT:
                return self.async_abort(reason="user_exit")

        schema = vol.Schema(
            {
                vol.Required("menu"): vol.In(
                    {
                        MENU_ADD_LIGNE: "➕ Ajouter une ligne",
                        MENU_ADD_MESSAGE: "➕ Ajouter un message",
                        MENU_DELETE: "➖ Supprimer un élément",
                        MENU_UPDATE_API: "🔑 Mettre à jour l’API Key",
                        MENU_EXIT: "🚪 Quitter",
                    }
                )
            }
        )

        return self.async_show_form(step_id="main_menu", data_schema=schema)

    # ---------------------------------------------------------
    # 6) Ajout ligne → nom final
    # ---------------------------------------------------------
    async def async_step_add_ligne_details(self, user_input=None):
        if user_input is not None:
            lignes = list(self.entry.data.get("lignes", []))

            lignes.append(
                {
                    "uuid": str(uuid.uuid4()),
                    "name": user_input[CONF_NAME],
                    "monitoring_ref": self._selected_stop_area,
                }
            )

            new_data = {**self.entry.data, "lignes": lignes}
            self.hass.config_entries.async_update_entry(self.entry, data=new_data)
            await self.hass.config_entries.async_reload(self.entry.entry_id)

            return await self.async_step_main_menu()

        schema = vol.Schema(
            {
                vol.Required(CONF_NAME): str,
            }
        )

        return self.async_show_form(
            step_id="add_ligne_details",
            data_schema=schema,
            description_placeholders={"help": "Donnez un nom à cette ligne."},
        )

    # ---------------------------------------------------------
    # 7) Ajout message
    # ---------------------------------------------------------
    async def async_step_add_message(self, user_input=None):
        if user_input is not None:
            messages = list(self.entry.data.get("messages", []))

            messages.append(
                {
                    "uuid": str(uuid.uuid4()),
                    "name": f"messages_{user_input[CONF_STOP_ID]}",
                    "stop_id": user_input[CONF_STOP_ID],
                }
            )

            new_data = {**self.entry.data, "messages": messages}
            self.hass.config_entries.async_update_entry(self.entry, data=new_data)
            await self.hass.config_entries.async_reload(self.entry.entry_id)

            return await self.async_step_main_menu()

        schema = vol.Schema({vol.Required(CONF_STOP_ID): str})
        return self.async_show_form(step_id="add_message", data_schema=schema)

    # ---------------------------------------------------------
    # 8) Suppression
    # ---------------------------------------------------------
    async def async_step_delete(self, user_input=None):
        lignes = self.entry.data.get("lignes", [])
        messages = self.entry.data.get("messages", [])

        choices = {}
        for i, l in enumerate(lignes):
            choices[f"ligne_{i}"] = f"Ligne : {l['name']}"
        for i, m in enumerate(messages):
            choices[f"msg_{i}"] = f"Message : {m['name']}"

        if not choices:
            return self.async_abort(reason="no_entries")

        if user_input is not None:
            key = user_input["entry"]
            if key.startswith("ligne_"):
                lignes.pop(int(key.split("_")[1]))
            if key.startswith("msg_"):
                messages.pop(int(key.split("_")[1]))

            new_data = {**self.entry.data, "lignes": lignes, "messages": messages}
            self.hass.config_entries.async_update_entry(self.entry, data=new_data)
            await self.hass.config_entries.async_reload(self.entry.entry_id)

            return await self.async_step_main_menu()

        schema = vol.Schema({vol.Required("entry"): vol.In(choices)})
        return self.async_show_form(step_id="delete", data_schema=schema)

    # ---------------------------------------------------------
    # 9) Mise à jour API key
    # ---------------------------------------------------------
    async def async_step_update_api(self, user_input=None):
        if user_input is not None:
            new_data = {**self.entry.data, CONF_API_KEY: user_input[CONF_API_KEY]}
            self.hass.config_entries.async_update_entry(self.entry, data=new_data)
            await self.hass.config_entries.async_reload(self.entry.entry_id)
            return await self.async_step_main_menu()

        schema = vol.Schema(
            {vol.Required(CONF_API_KEY, default=self.entry.data.get(CONF_API_KEY)): str}
        )
        return self.async_show_form(step_id="update_api", data_schema=schema)
